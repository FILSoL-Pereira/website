# Prisma connection strings (Supabase Postgres)
# Use DIRECT_URL for Prisma migrations/CLI and DATABASE_URL for app/server usage.
DATABASE_URL=postgresql://postgres.[YOUR_PROJECT_REF]:[YOUR_DB_PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# App environment: "development" pre-fills the registration form with test data.
# Omit or set to "production" in prod.
NEXT_PUBLIC_APP_ENV=development

# Admin credentials for /admin/checkin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
ADMIN_SESSION_SECRET=change-this-to-a-random-secret

# Optional: full site URL for absolute QR links (e.g. https://flisol.example.com)
# NEXT_PUBLIC_SITE_URL=